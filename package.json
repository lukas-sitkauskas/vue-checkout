{
  "name": "vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "format": "prettier --write src/**/*.{ts,vue}",
    "format:check": "prettier --check src/**/*.{ts,vue}"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "@tanstack/vue-query": "^5.99.2",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.15.1",
    "cleave.js": "^1.6.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cleave.js": "^1.4.12",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vue-tsc": "^3.2.7"
  }
}
